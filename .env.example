# Backend 환경 변수 예시 — 실제 값은 application-local.yml 또는 .env 로 분리하고 git 커밋 금지
# 자세한 설명은 docs repo 의 docs/ENV.md 참조

SPRING_PROFILES_ACTIVE=local
SERVER_PORT=8080

# DB
DB_URL=jdbc:postgresql://localhost:5432/farmily
DB_USERNAME=farmily
DB_PASSWORD=

# JWT
JWT_SECRET=
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

# Kakao OAuth
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=
KAKAO_ADMIN_KEY=

# 기상청 / 카카오 Local
KMA_SERVICE_KEY=
KMA_BASE_URL=https://apis.data.go.kr/1360000/VilageFcstInfoService_2.0
KAKAO_LOCAL_REST_KEY=

# AWS
AWS_REGION=ap-northeast-2
S3_BUCKET=
S3_REGION=ap-northeast-2

# Bedrock
BEDROCK_AGENT_ID=
BEDROCK_AGENT_ALIAS_ID=
AI_RESULT_BUCKET=

# 푸시
FCM_SERVICE_ACCOUNT_JSON=

# 포트원
PORTONE_API_KEY=
PORTONE_API_SECRET=
PORTONE_IMP_CODE=
PORTONE_WEBHOOK_SECRET=
PORTONE_TEST_MODE=true
